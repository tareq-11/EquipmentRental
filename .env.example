# Copy to .env, then generate the ignored secrets as documented in README.md.
POSTGRES_DB=equipment_rental
POSTGRES_USER=equipment_rental
POSTGRES_PORT=5433
# Set these only in your ignored local environment before first API startup.
# Jwt__SigningKey=<openssl rand -base64 48; must be at least 32 characters>
# Bootstrap__OrganizationName=Local Equipment Rental
# Bootstrap__AdminEmail=admin@example.test
# Bootstrap__AdminPassword=<12+ chars with uppercase, lowercase, number, symbol; <=72 UTF-8 bytes>
# Bootstrap__OperationsEmail=operations@example.test
# Bootstrap__OperationsPassword=<12+ chars with uppercase, lowercase, number, symbol; <=72 UTF-8 bytes>
# Mail__Mode=DevelopmentMailbox
# Mail__DevelopmentMailboxPath=/tmp/equipment-rental-dev-mail

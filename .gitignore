bin/
obj/
.vs/
.idea/
*.user

# Repository documentation and sanitized manual-testing evidence are source files.
# Ignore only local/generated artifacts rather than broad file extensions.

# Ignore all Markdown and text documentation files
*.md
*.txt
*.log

# Local environment values may contain database credentials.
.env
.env.*
!.env.example

web/node_modules/
web/.next/
web/.env.local

# Local manual-test captures may contain secrets or be regenerated at will.
docs/manual-testing/*.local.*
docs/manual-testing/*.secret.*
